{
  "manifest_version": 3,
  "name": "Pigeon",
  "description": "Mail Filter",
  "version": "0.1.0",
  "icons": {
  "16": "icons/icon.png",
  "48": "icons/icon.png",
  "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
  "service_worker": "background.js",
  "scripts": ["background.js"]
  },
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}